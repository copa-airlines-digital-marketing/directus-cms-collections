{
  "name": "directus-cms-collections",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "test": "doppler run -p cms-directus-updates -c dev -- vitest run",
    "test:cov": "doppler run -p cms-directus-updates -c dev -- vitest run --coverage",
    "test:local": "vitest run",
    "test:cov:local": "vitest run --coverage",
    "generate": "doppler run -p cms-directus-updates -c dev -- tsx scripts/generate.ts",
    "generate:local": "tsx scripts/generate.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ci": "pnpm generate && pnpm typecheck && pnpm test",
    "clean": "tsx scripts/clean-deprecated.ts",
    "clean:deprecated": "tsx scripts/clean-deprecated.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@directus/types": "^15.0.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.13",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.4.1+sha1.ec73125afa7b740b8fcafeab681883c7ec791a4b",
  "dependencies": {
    "@directus/sdk": "^19.0.1"
  },
  "lint-staged": {
    "**/*.{js,ts}": [
      "eslint --fix"
    ],
    "**/*": "prettier --write --ignore-unknown"
  }
}
